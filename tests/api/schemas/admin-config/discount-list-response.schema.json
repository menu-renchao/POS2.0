{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResponseListDiscountsResponse",
  "description": "自动化业务契约：用于校验 GET /api/discount/list 当前应稳定返回的关键字段；required 不等同于 OpenAPI 文档中的必填标记。",
  "type": "object",
  "required": ["code", "msg", "data"],
  "properties": {
    "code": {
      "type": "integer"
    },
    "msg": {
      "type": "string"
    },
    "traceId": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["discounts"],
      "properties": {
        "discounts": {
          "type": "array",
          "items": {
            "title": "DiscountResponse",
            "description": "自动化业务契约要求非空折扣记录返回这些关键字段，便于后续业务链路读取。",
            "type": "object",
            "required": ["id", "name", "rate"],
            "properties": {
              "id": {
                "type": ["integer", "string"]
              },
              "name": {
                "type": "string"
              },
              "rate": {
                "type": "number"
              },
              "rateType": {
                "type": "integer"
              },
              "description": {
                "type": ["string", "null"]
              }
            }
          }
        }
      }
    }
  }
}
