{
  "name": "pos-super-new-ui-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright + TypeScript UI automation project for the POS frontend",
  "scripts": {
    "test": "playwright test",
    "test:scripts": "node --test tests/scripts/codegen.unit.test.mjs tests/scripts/capture-case.unit.test.mjs tests/scripts/generate-jenkins-test-tree.unit.test.mjs tests/scripts/jenkinsfile-ui-scope.unit.test.mjs tests/scripts/check-ui-architecture.unit.test.mjs",
    "test:api": "playwright test tests/api/business tests/api/contracts tests/api/endpoints tests/api/unit --project=api",
    "test:api:cleanup": "playwright test tests/api/maintenance --project=api",
    "test:py-migrate": "playwright test tests/py-migrate",
    "test:headed": "playwright test --headed",
    "jenkins:test-tree": "node scripts/generate-jenkins-test-tree.mjs",
    "codegen": "node scripts/codegen.mjs",
    "capture:case": "node scripts/capture-case.mjs",
    "diagnostics:report": "playwright test --config scripts/diagnostics/playwright.config.ts",
    "lint:ui-architecture": "node scripts/check-ui-architecture.mjs",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.6.0",
    "allure": "3.14.1",
    "allure-playwright": "^3.6.0",
    "mysql2": "^3.22.5",
    "typescript": "^5.9.3"
  }
}
